{
  "manifest_version": 3,
  "name": "anyside",
  "version": "0.1.0",
  "description": "Keep ChatGPT, Claude, Gemini, NotebookLM, or a custom AI URL in Chrome's Side Panel.",
  "minimum_chrome_version": "116",
  "icons": {
    "16": "assets/icons/icon-16.png",
    "32": "assets/icons/icon-32.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },
  "action": {
    "default_title": "Open anyside",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "32": "assets/icons/icon-32.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "contextMenus",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "offscreen",
    "scripting",
    "sidePanel",
    "storage",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://*.chatgpt.com/*",
    "https://claude.ai/*",
    "https://*.claude.ai/*",
    "https://gemini.google.com/*",
    "https://notebooklm.google.com/*",
    "https://perplexity.ai/*",
    "https://*.perplexity.ai/*"
  ],
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "options_page": "src/options/index.html",
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://claude.ai/*",
        "https://*.claude.ai/*",
        "https://gemini.google.com/*",
        "https://notebooklm.google.com/*",
        "https://perplexity.ai/*",
        "https://*.perplexity.ai/*"
      ],
      "js": ["dist/content/aiInputAgent.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open anyside side panel"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "allow_framing_ai_sites",
        "enabled": false,
        "path": "rules/allow-framing-ai-sites.json"
      }
    ]
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; img-src 'self' https: data:; frame-src https: http://localhost:* http://127.0.0.1:*;"
  }
}
